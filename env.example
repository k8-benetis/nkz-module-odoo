# Nekazari Odoo ERP Module - Environment Variables
#
# Copy this file to .env and fill in the values.
#
# Author: Kate Benetis <kate@robotika.cloud>
# Company: Robotika
# License: AGPL-3.0

# =============================================================================
# API Settings
# =============================================================================
DEBUG=false
API_TITLE=Nekazari Odoo ERP Module API
API_VERSION=1.0.0

# =============================================================================
# Odoo Connection
# =============================================================================
ODOO_HOST=odoo-service
ODOO_PORT=8069
ODOO_MASTER_PASSWORD=your_secure_master_password
ODOO_TEMPLATE_DB=nkz_odoo_template

# =============================================================================
# PostgreSQL for Odoo (dedicated instance)
# =============================================================================
ODOO_DB_HOST=postgres-odoo-service
ODOO_DB_PORT=5432
ODOO_DB_USER=odoo
ODOO_DB_PASSWORD=your_secure_db_password

# =============================================================================
# Nekazari Platform Database
# =============================================================================
DATABASE_URL=postgresql://postgres:password@postgresql-service:5432/nekazari

# =============================================================================
# Redis
# =============================================================================
REDIS_URL=redis://redis-service:6379/0

# =============================================================================
# Keycloak Authentication (replace YOUR_DOMAIN at deploy)
# =============================================================================
KEYCLOAK_URL=https://auth.YOUR_DOMAIN/auth
KEYCLOAK_REALM=nekazari
KEYCLOAK_CLIENT_ID=nekazari-api
# JWKS_URL is auto-generated from KEYCLOAK_URL if not set

# =============================================================================
# NGSI-LD Context Broker
# =============================================================================
ORION_URL=http://orion-ld-service:1026

# =============================================================================
# N8N Integration
# =============================================================================
N8N_URL=http://n8n-service:5678
N8N_WEBHOOK_SECRET=your_webhook_secret

# =============================================================================
# Intelligence Module
# =============================================================================
INTELLIGENCE_API_URL=http://intelligence-api-service:8000

# =============================================================================
# CORS (replace YOUR_DOMAIN; add Odoo subdomain if used for links)
# =============================================================================
ALLOWED_ORIGINS_STR=https://nekazari.YOUR_DOMAIN,http://localhost:5010

# Optional: public Odoo URL for "Open in Odoo" links. Empty = relative path /odoo (same origin).
ODOO_URL=
